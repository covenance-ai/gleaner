digraph ingestion {
    rankdir=TB
    bgcolor="white"
    fontname="Helvetica"
    node [fontname="Helvetica", fontsize=10, style="filled,rounded", shape=box]
    edge [fontname="Helvetica", fontsize=8, color="#555555"]
    newrank=true
    compound=true
    ranksep=0.4
    nodesep=0.4

    // ═══ ENTRY POINTS (side by side) ═══

    subgraph cluster_hook {
        label="  Plugin (SessionEnd Hook)  "
        style="filled,rounded"
        fillcolor="#E8F5E9"
        color="#43A047"
        fontcolor="#2E7D32"
        fontsize=11
        margin=8

        hook_entry [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Claude Code session ends</b></td></tr>
            <tr><td><font point-size="8" color="#555555">stdin: {session_id, cwd}</font></td></tr>
            <tr><td><font point-size="8" color="#555555">finds ~/.claude/…/{id}.jsonl</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>upload.py:main()</i></font></td></tr>
            </table>>
            fillcolor="#C8E6C9" color="#43A047"
        ]
    }

    subgraph cluster_backfill {
        label="  Backfill (Manual CLI)  "
        style="filled,rounded"
        fillcolor="#E3F2FD"
        color="#1E88E5"
        fontcolor="#1565C0"
        fontsize=11
        margin=8

        bf_scan [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>gleaner backfill</b></td></tr>
            <tr><td><font point-size="8" color="#555555">~/.claude/projects/**/*.jsonl</font></td></tr>
            <tr><td><font point-size="8" color="#555555">~/.cursor/…/agent-transcripts/</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>backfill.py:run()</i></font></td></tr>
            </table>>
            fillcolor="#BBDEFB" color="#1E88E5"
        ]
        bf_dedup [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Deduplicate</b></td></tr>
            <tr><td><font point-size="8" color="#555555">skip already-uploaded (unless --force)</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>backfill.py:get_existing_session_ids()</i></font></td></tr>
            </table>>
            fillcolor="#BBDEFB" color="#1E88E5"
        ]
        bf_scan -> bf_dedup
    }

    // ═══ SHARED PIPELINE (vertical) ═══

    subgraph cluster_pipeline {
        label=<
        <table border="0" cellborder="0"><tr>
        <td><font point-size="11" color="#E65100"><b> Processing Pipeline </b></font></td>
        </tr><tr>
        <td><font point-size="8" color="#E65100">Python &#8212; gleaner/ package</font></td>
        </tr></table>>
        style="filled,rounded"
        fillcolor="#FFF8E1"
        color="#FFB300"
        fontsize=11
        margin=8

        parse [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Parse transcript</b></td></tr>
            <tr><td><font point-size="8" color="#555555">counts, timestamps, topic</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>upload.py:parse_transcript()</i></font></td></tr>
            </table>>
            fillcolor="#FFE082" color="#FFB300"
        ]

        worthless [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Worthless?</b></td></tr>
            <tr><td><font point-size="8" color="#555555">no user/assistant msgs</font></td></tr>
            <tr><td><font point-size="8" color="#555555">or only rate-limit errors</font></td></tr>
            </table>>
            shape=diamond fillcolor="#FFE082" color="#FFB300"
        ]

        skip [label="Skip" fillcolor="#FFCDD2" color="#E53935" fontcolor="#B71C1C" fontsize=9]

        tag [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Classify</b></td></tr>
            <tr><td><font point-size="8" color="#555555">source: human | kodo | test</font></td></tr>
            <tr><td><font point-size="8" color="#555555">task_type: dev | swe_bench | ...</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>tags.py:tag_session()</i></font></td></tr>
            </table>>
            fillcolor="#FFE082" color="#FFB300"
        ]

        scrub [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Scrub PII &amp; secrets</b></td></tr>
            <tr><td><font point-size="8" color="#555555">Presidio or legacy regex</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>scrub.py:scrub_text()</i></font></td></tr>
            </table>>
            fillcolor="#FFE082" color="#FFB300"
        ]

        compress [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="1">
            <tr><td><b>Gzip + base64</b></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>upload.py:upload()</i></font></td></tr>
            </table>>
            fillcolor="#FFE082" color="#FFB300"
        ]

        parse -> worthless
        worthless -> skip [label="yes" color="#E53935" fontcolor="#E53935"]
        worthless -> tag [label="no" color="#43A047" fontcolor="#2E7D32"]
        tag -> scrub -> compress
    }

    // ═══ SERVER ═══

    subgraph cluster_server {
        label=<<table border="0" cellborder="0"><tr><td width="24"><img src="/Users/ikamen/ai-workspace/ilya/gleaner/icons/cloud_run.png"/></td><td><font point-size="11"> Cloud Run </font></td></tr></table>>
        style="filled,rounded"
        fillcolor="#EDE7F6"
        color="#7E57C2"
        fontcolor="#6A1B9A"
        fontsize=11
        margin=8
        labeljust=l

        api [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="2">
            <tr><td><b>POST /api/session</b></td></tr>
            <tr><td><font point-size="8" color="#555555">metadata + gzipped transcript</font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>server/server.py</i></font></td></tr>
            </table>>
            fillcolor="#D1C4E9" color="#7E57C2"
        ]

        storage [
            label=<
            <table border="0" cellborder="0" cellspacing="0" cellpadding="2">
            <tr><td><font point-size="9"><b>Firestore</b> + <b>GCS</b></font></td></tr>
            <tr><td><font point-size="7" color="#888888"><i>server/db.py</i></font></td></tr>
            </table>>
            fillcolor="#D1C4E9" color="#7E57C2"
        ]

        api -> storage [color="#7E57C2"]
    }

    // ═══ CONFIG ═══

    config [
        label=<
        <table border="1" cellborder="0" cellspacing="0" cellpadding="2" bgcolor="#F3E5F5" color="#AB47BC" style="rounded">
        <tr><td><font point-size="8"><b>~/.config/gleaner.json</b> (url + token)</font></td></tr>
        <tr><td><font point-size="8"><b>~/.claude/settings.json</b> (hook registration)</font></td></tr>
        <tr><td><font point-size="7" color="#888888"><i>config.py</i></font></td></tr>
        </table>>
        shape=none
    ]

    // ═══ EDGES ═══

    // Side-by-side hints
    {rank=same; hook_entry; bf_scan}
    {rank=same; compress; api}

    // Entry → pipeline
    hook_entry -> parse [
        label=" 1 session "
        color="#43A047" fontcolor="#2E7D32" penwidth=1.5
    ]
    bf_dedup -> parse [
        label=" N sessions (loop) "
        color="#1E88E5" fontcolor="#1565C0" penwidth=1.5
    ]

    // Pipeline → server (horizontal)
    compress -> api [color="#E65100" penwidth=1.5]

    // Config (unobtrusive)
    config -> hook_entry [style=dashed color="#BBBBBB" arrowsize=0.5 constraint=false]
    config -> bf_scan [style=dashed color="#BBBBBB" arrowsize=0.5 constraint=false]
}
